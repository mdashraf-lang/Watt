# ── GO WATT backend config (copy to .env, fill in) ──────────────────────────
NODE_ENV=production
PORT=8080

# PostgreSQL on your dedicated server
DATABASE_URL=postgres://gowatt:CHANGE_ME@localhost:5432/gowatt

# Auth tokens (generate strong random values: openssl rand -hex 48)
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS — the app's origin(s); use * only for early testing
CORS_ORIGIN=*

# SMTP (password reset / verification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@gowatt.om

# Integrations (ported from the edge functions)
THAWANI_BASE_URL=https://checkout.thawani.om
THAWANI_SECRET_KEY=
THAWANI_PUBLISHABLE_KEY=
TUYA_BASE_URL=https://openapi.tuyaeu.com
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=

# Background-job internal secret (cron → protected job endpoints)
JOB_SECRET=CHANGE_ME
