# ============================================================================
#  GO WATT — backend secrets (copy to secrets.env and fill every ⟨FILL⟩)
#  These go into the self-hosted Supabase docker/.env. NEVER commit real values.
# ============================================================================

# ── Core Supabase (docker/.env) ─────────────────────────────────────────────
POSTGRES_PASSWORD=⟨FILL: strong db password you choose⟩
JWT_SECRET=⟨FILL: openssl rand -base64 48⟩
ANON_KEY=⟨FILL: generate from JWT_SECRET (Supabase key generator)⟩
SERVICE_ROLE_KEY=⟨FILL: generate from JWT_SECRET (Supabase key generator)⟩
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=⟨FILL: strong password for the Studio login⟩

SITE_URL=https://api.gowatt.om
API_EXTERNAL_URL=https://api.gowatt.om
SUPABASE_PUBLIC_URL=https://api.gowatt.om

# ── SMTP (so signup / password-reset emails send) ───────────────────────────
SMTP_HOST=⟨FILL: e.g. smtp.gmail.com or your provider⟩
SMTP_PORT=587
SMTP_USER=⟨FILL⟩
SMTP_PASS=⟨FILL⟩
SMTP_SENDER_NAME=GO WATT
SMTP_ADMIN_EMAIL=⟨FILL: from address, e.g. no-reply@gowatt.om⟩

# ── EDGE FUNCTION SECRETS (add to the `functions` service env in docker/.env) ─
# Thawani (payments)
THAWANI_BASE_URL=https://checkout.thawani.om
THAWANI_SECRET_KEY=⟨FILL: from your Thawani merchant account⟩
THAWANI_PUBLISHABLE_KEY=⟨FILL: from your Thawani merchant account⟩

# Tuya (smart-switch hardware control)
TUYA_BASE_URL=https://openapi.tuyaeu.com
TUYA_CLIENT_ID=⟨FILL: from Tuya IoT platform⟩
TUYA_CLIENT_SECRET=⟨FILL: from Tuya IoT platform⟩

# Job secrets (invent long random strings; used by cron to call the functions)
AUTO_SHUTOFF_SECRET=⟨FILL: openssl rand -hex 24⟩
DISBURSE_SECRET=⟨FILL: openssl rand -hex 24⟩
PUSH_INTERNAL_SECRET=⟨FILL: openssl rand -hex 24⟩

# Email sender for send-watt-email (if it uses its own key)
WATT_EMAIL_FROM=⟨FILL: e.g. no-reply@gowatt.om⟩

# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically to
# functions by the stack — no need to set them yourself.
