{
  "expo": {
    "name": "GO WATT",
    "slug": "watt-ev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.watt.ev",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Watt uses your location to show nearby EV charging stations on the map.",
        "NSPhotoLibraryUsageDescription": "Watt needs access to your photos so you can set a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.watt.ev",
      "adaptiveIcon": {
        "backgroundColor": "#14532D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "watt",
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Watt uses your location to show nearby EV charging stations on the map."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#10B981"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "57c3c770-33c9-494c-959a-132747ed71dc"
      }
    }
  }
}
