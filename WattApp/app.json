{
  "expo": {
    "name": "Watt",
    "slug": "watt-ev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.watt.ev",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Watt uses your location to show nearby EV charging stations on the map.",
        "NSPhotoLibraryUsageDescription": "Watt needs access to your photos so you can set a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.watt.ev",
      "adaptiveIcon": {
        "backgroundColor": "#14532D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAzbx3XZ-Zfqop62gfKhuRIRPNSQXruy1Y"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "watt",
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Watt uses your location to show nearby EV charging stations on the map."
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "color": "#10B981"
        }
      ]
    ]
  }
}
